# MnemoNAS Docker Compose settings.
# Copy to .env before running docker compose. Compose reads .env automatically.

# Run the container as your host user so /data files remain editable outside Docker.
# On Linux, set these with:
#   id -u
#   id -g
MNEMONAS_UID=1000
MNEMONAS_GID=1000

# Host port for Web UI, REST API, and WebDAV.
# Change this if another service already uses 8080.
MNEMONAS_HTTP_PORT=8080

# Host directory mounted into the container as /data.
# Keep this as an absolute path; Compose does not expand "~".
# Leave empty to use ${HOME}/.mnemonas from docker-compose.yml.
MNEMONAS_DATA_DIR=

# Local source builds default to a local image tag.
MNEMONAS_IMAGE=mnemonas:local
MNEMONAS_VERSION=local
MNEMONAS_BUILD_TIME=unknown

# Optional build image overrides for private mirrors or regional caches.
# RUST_IMAGE=rust:1.92
# NODE_IMAGE=node:22-bookworm-slim
# GO_IMAGE=golang:1.25.9-alpine
# RUNTIME_IMAGE=debian:bookworm-slim
