{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs",
    "test:ui": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs --ui",
    "test:run": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "storycap --serverCmd 'npm run storybook -- --ci' http://localhost:6006 && reg-cli __screenshots__ __screenshots__/expected __screenshots__/diff -R report.html",
    "test:visual:update": "storycap --serverCmd 'npm run storybook -- --ci' http://localhost:6006 && cp -r __screenshots__/*.png __screenshots__/expected/",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@heroui/react": "^2.8.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.15",
    "@tanstack/react-virtual": "^3.13.13",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^17.6.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
