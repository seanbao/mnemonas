{
  "name": "mnemonas-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'npm run typecheck'"
    ]
  },
  "scripts": {
    "predev": "node ./scripts/check-node.cjs",
    "dev": "vite",
    "prebuild": "node ./scripts/check-node.cjs",
    "build": "tsc -b && vite build",
    "prelint": "node ./scripts/check-node.cjs",
    "lint": "npm run check:scripts && npm run check:identity && npm run check:queries && npm run check:testids && npm run check:ts-suppressions && npm run check:console && npm run check:test-focus && npm run check:a11y && eslint . && node ./scripts/check-eslint-button-rule.mjs",
    "check:scripts": "node ./scripts/check-node-scripts.cjs",
    "check:identity": "node ./scripts/check-project-identity.cjs",
    "check:queries": "node ./scripts/check-testing-library-queries.cjs",
    "check:testids": "node ./scripts/check-production-testids.cjs",
    "check:ts-suppressions": "node ./scripts/check-production-ts-suppressions.cjs",
    "check:console": "node ./scripts/check-production-console.cjs",
    "check:test-focus": "node ./scripts/check-test-focus.cjs",
    "check:a11y": "node ./scripts/check-icon-button-labels.cjs",
    "pretypecheck": "node ./scripts/check-node.cjs",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.e2e.json",
    "pretypecheck:e2e": "node ./scripts/check-node.cjs",
    "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
    "prepreview": "node ./scripts/check-node.cjs",
    "preview": "vite preview",
    "check:node": "node ./scripts/check-node.cjs",
    "pretest": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "pretest:ui": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "pretest:run": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "pretest:coverage": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "test": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs",
    "test:ui": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs --ui",
    "test:run": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs run",
    "test:coverage": "node -r ./scripts/vitest-preload.cjs ./node_modules/vitest/vitest.mjs run --coverage",
    "pretest:e2e": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "test:e2e": "node ./scripts/playwright.cjs test",
    "pretest:e2e:navigation": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "test:e2e:navigation": "node ./scripts/playwright.cjs test navigation.spec.ts",
    "pretest:e2e:ui": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "test:e2e:ui": "node ./scripts/playwright.cjs test --ui",
    "pretest:e2e:update": "node ./scripts/check-node.cjs && npm run check:test-focus",
    "test:e2e:update": "node ./scripts/playwright.cjs test --update-snapshots",
    "prepare": "node ./scripts/prepare-husky.cjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@heroui/react": "^2.8.7",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.15",
    "@tanstack/react-virtual": "^3.13.13",
    "autoprefixer": "^10.4.23",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.562.0",
    "postcss": "^8.5.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.7.0",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.1.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.2"
  }
}
